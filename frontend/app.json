{
  "expo": {
    "name": "The Adiraa",
    "slug": "adiraa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/adiraa.png",
    "scheme": "adiraa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adiraa.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.adiraa.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/adiraa.png",
        "backgroundImage": "./assets/images/adiraa.png",
        "monochromeImage": "./assets/images/adiraa.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/adiraa.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/adiraa.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "544c2015-7cf0-4794-a774-b12e84b543a2"
      }
    },
    "owner": "feathrtech"
  }
}
